# ── Required ──────────────────────────────────────────────────────────────────

# GitHub personal access token
# Needs: repo (read) + actions (read) scopes
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Anthropic API key — used by the Explanation and Noise Detector agents
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Target Repository ─────────────────────────────────────────────────────────

# The GitHub repo to collect CI history from and predict against.
# Format: "owner/repo"
# For your own repo: "mycompany/my-backend"
# For demo/testing: "pallets/flask"
TARGET_REPO=pallets/flask

# ── Optional Tuning ───────────────────────────────────────────────────────────

# How many commits to pull from GitHub history (default: 100)
# More = better predictions, slower build
# Recommended: 200-500 for a good balance
MAX_COMMITS=500

# How many similar historical diffs to retrieve per prediction (default: 20)
# TOP_K=20

# How many tests to include in the final ranked report (default: 12)
# TOP_N=12

# Minimum failure score to flag a test (default: 0.1)
# Lower = more tests flagged, higher recall but lower precision
# MIN_SCORE=0.1
